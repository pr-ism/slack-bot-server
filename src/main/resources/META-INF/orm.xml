<?xml version="1.0" encoding="UTF-8"?>
<entity-mappings xmlns="https://jakarta.ee/xml/ns/persistence/orm"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence/orm https://jakarta.ee/xml/ns/persistence/orm/orm_3_1.xsd"
                 version="3.1">
    <entity class="com.slack.bot.infrastructure.interaction.box.in.SlackInteractionInbox" access="FIELD">
        <attributes>
            <element-collection name="processingLeaseDetails" fetch="EAGER"
                                target-class="com.slack.bot.infrastructure.common.BoxProcessingLeaseDetail">
                <collection-table name="slack_interaction_inbox_processing_lease_details">
                    <join-column name="owner_id"/>
                </collection-table>
            </element-collection>
            <element-collection name="processedTimeDetails" fetch="EAGER"
                                target-class="com.slack.bot.infrastructure.common.BoxEventTimeDetail">
                <collection-table name="slack_interaction_inbox_processed_time_details">
                    <join-column name="owner_id"/>
                </collection-table>
            </element-collection>
            <element-collection name="failedTimeDetails" fetch="EAGER"
                                target-class="com.slack.bot.infrastructure.common.BoxEventTimeDetail">
                <collection-table name="slack_interaction_inbox_failed_time_details">
                    <join-column name="owner_id"/>
                </collection-table>
            </element-collection>
            <element-collection name="failureDetails" fetch="EAGER"
                                target-class="com.slack.bot.infrastructure.common.BoxFailureDetail">
                <collection-table name="slack_interaction_inbox_failure_details">
                    <join-column name="owner_id"/>
                </collection-table>
            </element-collection>
        </attributes>
    </entity>
    <entity class="com.slack.bot.infrastructure.interaction.box.in.SlackInteractionInboxHistory" access="FIELD">
        <attributes>
            <element-collection name="failureDetails" fetch="EAGER"
                                target-class="com.slack.bot.infrastructure.common.BoxHistoryFailureDetail">
                <collection-table name="slack_interaction_inbox_history_failure_details">
                    <join-column name="owner_id"/>
                </collection-table>
            </element-collection>
        </attributes>
    </entity>
</entity-mappings>
